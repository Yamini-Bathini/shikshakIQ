# =============================================================================
# ShikshakIQ — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For production (Fly.io), set these via: fly secrets set KEY=VALUE
# =============================================================================

# --- Security ---
SECRET_KEY="change-this-to-a-long-random-string"
JWT_SECRET_KEY="change-this-to-another-long-random-string"

# --- Database ---
# For local dev: SQLite (default, no change needed)
# For production: PostgreSQL (set automatically by Fly.io when you attach a DB)
#   Include ?sslmode=require if your provider mandates SSL:
#   DATABASE_URL="postgresql://user:password@host:5432/shikshakiq?sslmode=require"
#
# Connection pooling — these only apply when DATABASE_URL uses PostgreSQL;
# they are ignored for SQLite.  The defaults are safe for most small/medium apps:
DB_POOL_SIZE="10"
DB_POOL_MAX_OVERFLOW="10"
DB_POOL_RECYCLE="1800"         # seconds (30 min — must be < PostgreSQL's connection timeout)
DB_POOL_PRE_PING="true"         # test connection before using it from the pool

# --- Google Gemini AI (REQUIRED for AI features) ---
GEMINI_API_KEY="your-gemini-api-key-here"
# Optional: comma-separated list for automatic key rotation
# GEMINI_API_KEYS="key1,key2,key3"

# --- App Settings ---
DEBUG="False"
